{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789"]
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": [546356584],
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "groupAllowFrom": [546356584],
      "historyLimit": 50,
      "groups": {
       "-1003778969973": {
         "allowFrom": [546356584],
         "requireMention": false,
         "topics": {
           "1": { "requireMention": false, "systemPrompt": "Allgemeines Topic – hier geht es um alles mögliche." },
           "2": { "requireMention": false, "systemPrompt": "To-Do-Topic – hier geht es um Aufgaben, Planung und Produktivität." }
        }
       }
      }
    }
  },

  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },

  "models": {
    "mode": "merge",
    
    "providers": {
      "zen-openai": {
        "baseUrl": "https://opencode.ai/zen/v1",
        "api": "openai",
        "models": [
          {
            "id": "gpt-5.4-mini",
            "name": "GPT 5.4 Mini",
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "gpt-5-nano",
            "name": "GPT 5 Nano",
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "zen-anthropic": {
        "baseUrl": "https://opencode.ai/zen/v1",
        "api": "anthropic",
        "models": [
          {
            "id": "claude-haiku-4-5",
            "name": "Claude Haiku 4.5",
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "contextWindow": 1000000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      },
      "zen-google": {
        "baseUrl": "https://opencode.ai/zen/v1",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "gemini-3-flash",
            "name": "Gemini 3 Flash",
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      },
      "zen": {
        "baseUrl": "https://opencode.ai/zen/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "minimax-m2.5-free",
            "name": "MiniMax M2.5 Free",
            "contextWindow": 205000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3.6-plus-free",
            "name": "Qwen3.6 Plus Free",
            "contextWindow": 164000,
            "maxTokens": 8192
          },
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "contextWindow": 262000,
            "maxTokens": 8192
          },
          {
            "id": "glm-5",
            "name": "GLM 5",
            "contextWindow": 205000,
            "maxTokens": 8192
          }
        ]
      },
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "apiKey": "${GOOGLE_HEARTBEAT_API_KEY}",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "gemini-2.0-flash-lite",
            "name": "Gemini 2.0 Flash Lite"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zen/minimax-m2.5-free",
        "fallbacks": [
          "zen-anthropic/claude-haiku-4-5",
          "zen-openai/gpt-5-nano"
        ]
      },
      "models": {
        "zen-openai/gpt-5-nano": { "alias": "nano" },
        "zen-google/gemini-3-flash": { "alias": "gemini" },
        "zen/qwen3.6-plus-free": { "alias": "qwen" },
        "zen/minimax-m2.5-free": { "alias": "minimax" },
        "zen/kimi-k2.5": { "alias": "kimi" },
        "zen/glm-5": { "alias": "glm" },
        "zen-anthropic/claude-haiku-4-5": { "alias": "haiku" },
        "zen-anthropic/claude-sonnet-4-6": { "alias": "sonnet" },
        "zen-anthropic/claude-opus-4-6": { "alias": "opus" },
        "zen-openai/gpt-5.4-mini": { "alias": "gpt" }
      },
      "heartbeat": {
        "model": "google/gemini-2.0-flash-lite",
        "every": "55m",
        "target": "last"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "gemini"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },

  "messages": {
    "ackReactionScope": "group-mentions"
  },

  "auth": {
    "profiles": {
      "zen:manual": {
        "provider": "zen",
        "mode": "api_key"
      },
      "zen-anthropic:manual": {
        "provider": "zen-anthropic",
        "mode": "api_key"
      },
      "zen-openai:manual": {
        "provider": "zen-openai",
        "mode": "api_key"
      },
      "zen-google:manual": {
        "provider": "zen-google",
        "mode": "api_key"
      }
    },
    "order": {
      "zen": ["zen:manual"],
      "zen-anthropic": ["zen-anthropic:manual"],
      "zen-openai": ["zen-openai:manual"],
      "zen-google": ["zen-google:manual"]
    }
  },

  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  }
}
