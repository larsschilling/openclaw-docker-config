{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "force": {
    "mode": "full"
  },

  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "automerge": true,
  "branchPrefix": "renovate-updates/",
  "recreateWhen": "always",
  "rebaseWhen": "behind-base-branch",

  "pruneBranchAfterAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)docker-compose\\.yml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[\\w-]+) depName=(?<depName>[\\w-\\/@]+)(?: versioning=(?<versioning>[\\w-]+))?\\s+ARG\\s+(?<variable>\\w+)=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["openclaw"],
      "automerge": true,
      "branchPrefix": "renovate-updates/",
      "recreateWhen": "always",
      "rebaseWhen": "behind-base-branch",
  "branchPrefix": "renovate-updates/",
  "recreateWhen": "always",
  "rebaseWhen": "behind-base-branch",

      "minimumReleaseAge": "1h"
    },
    {
      "matchCategories": ["docker"],
      "addLabels": ["docker"]
    }
  ]
}
