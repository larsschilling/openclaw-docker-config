{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "merge-commit",
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["openclaw"],
      "versioning": "npm",
      "automerge": true,
      "minimumReleaseAge": "1h"
    }
  ]
}
